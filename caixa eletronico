import tkinter as tk
from tkinter import messagebox

class CaixaEletronico:
    def __init__(self, janela):
        self.janela = janela
        self.janela.title("Caixa Eletrônico")
        self.janela.geometry("400x300")

        self.saldo = 1000.00  

    
        titulo = tk.Label(
            janela,
            text="CAIXA ELETRÔNICO",
            font=("Arial", 16, "bold")
        )
        titulo.pack(pady=10)

        
        self.label_saldo = tk.Label(
            janela,
            text=f"Saldo: R$ {self.saldo:.2f}",
            font=("Arial", 12)
        )
        self.label_saldo.pack(pady=10)

        
        tk.Label(janela, text="Digite o valor:").pack()

        self.entry_valor = tk.Entry(janela)
        self.entry_valor.pack(pady=5)

        
        frame_botoes = tk.Frame(janela)
        frame_botoes.pack(pady=10)

        btn_depositar = tk.Button(
            frame_botoes,
            text="Depositar",
            command=self.depositar,
            bg="green",
            fg="white",
            width=10
        )
        btn_depositar.grid(row=0, column=0, padx=5)

        btn_sacar = tk.Button(
            frame_botoes,
            text="Sacar",
            command=self.sacar,
            bg="red",
            fg="white",
            width=10
        )
        btn_sacar.grid(row=0, column=1, padx=5)

        btn_consultar = tk.Button(
            frame_botoes,
            text="Consultar",
            command=self.consultar_saldo,
            bg="blue",
            fg="white",
            width=10
        )
        btn_consultar.grid(row=0, column=2, padx=5)

    def atualizar_saldo(self):
        self.label_saldo.config(text=f"Saldo: R$ {self.saldo:.2f}")

    def depositar(self):
        try:
            valor = float(self.entry_valor.get())

            if valor <= 0:
                messagebox.showerror(
                    "Erro",
                    "Digite um valor maior que zero."
                )
                return

            self.saldo += valor
            self.atualizar_saldo()

            messagebox.showinfo(
                "Sucesso",
                f"Depósito de R$ {valor:.2f} realizado."
            )

            self.entry_valor.delete(0, tk.END)

        except ValueError:
            messagebox.showerror(
                "Erro",
                "Digite um valor válido."
            )

    def sacar(self):
        try:
            valor = float(self.entry_valor.get())

            if valor <= 0:
                messagebox.showerror(
                    "Erro",
                    "Digite um valor maior que zero."
                )
                return

            if valor > self.saldo:
                messagebox.showwarning(
                    "Saldo Insuficiente",
                    "Você não possui saldo suficiente."
                )
                return

            self.saldo -= valor
            self.atualizar_saldo()

            messagebox.showinfo(
                "Sucesso",
                f"Saque de R$ {valor:.2f} realizado."
            )

            self.entry_valor.delete(0, tk.END)

        except ValueError:
            messagebox.showerror(
                "Erro",
                "Digite um valor válido."
            )

    def consultar_saldo(self):
        messagebox.showinfo(
            "Saldo",
            f"Seu saldo atual é R$ {self.saldo:.2f}"
        )


janela = tk.Tk()
app = CaixaEletronico(janela)
janela.mainloop()